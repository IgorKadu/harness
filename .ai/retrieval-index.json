{
  "$schema": "./retrieval-index.schema.json",
  "version": "1.0.0",
  "updated": "2026-06-05",
  "description": "Mapa intenção/keyword → ≤5 arquivos. Roteamento determinístico, consumido por bin/os.mjs. Cada rota respeita o teto de 5 paths (invariante de contexto, ADR-0022).",
  "budget": {
    "core_token_cap": 600,
    "state_of_world_token_cap": 1200,
    "working_set_token_cap": 15000,
    "max_files_per_route": 5
  },
  "always": [
    ".ai/CONSTITUTION.md",
    ".ai/memory/state-of-world.md"
  ],
