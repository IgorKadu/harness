      "id": "bug",
      "triggers": [
        "bug",
        "erro",
        "error",
        "falha",
        "crash",
        "não funciona",
        "nao funciona",
        "stacktrace",
        "exception",
        "quebrou"
      ],
      "load": [
        ".ai/knowledge/tools/debugging.md",
        ".ai/memory/logs/errors-log.md"
      ]
    },
