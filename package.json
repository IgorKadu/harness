{
  "name": "@igorkadu/harness",
  "version": "0.9.4",
  "type": "module",
  "description": "Harness — Lean AI OS: a ferramenta que ajuda a criar outras ferramentas. Contexto por tarefa, nao por projeto (retrieval-first).",
  "bin": {
    "harness": "bin/os.mjs",
    "os": "bin/os.mjs"
  },
  "scripts": {
    "os": "node bin/os.mjs",
    "doctor": "node bin/os.mjs doctor",
    "mcp": "node bin/os.mjs mcp",
    "test": "node --test test/*.test.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "files": [
    "bin/",
    "src/",
    "server/",
    ".ai/CONSTITUTION.md",
    ".ai/retrieval-index.json",
    ".ai/retrieval-index.schema.json",
    ".ai/knowledge/",
    ".ai/bootstrap/",
    ".ai/specs/ADR/_TEMPLATE.md",
    "CLAUDE.md",
    "AGENTS.md",
    "README.md",
    "CONNECT.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IgorKadu/harness.git"
  },
  "homepage": "https://github.com/IgorKadu/harness#readme",
  "bugs": {
    "url": "https://github.com/IgorKadu/harness/issues"
  },
  "keywords": [
    "ai",
    "llm",
    "mcp",
    "context",
    "retrieval",
    "claude",
    "agent",
    "developer-tools"
  ],
  "publishConfig": {
    "access": "public"
  }
}
